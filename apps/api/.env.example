# RegAxis RIM — API Environment Variables
# Copy this file to .env and fill in the values

# ── Application ─────────────────────────────────────────────────────────────
# Environment: local | demo | production
APP_ENV=local
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Local: use Docker Compose (docker-compose up postgres)
# Demo/Production: AWS RDS PostgreSQL via RDS Proxy
DATABASE_URL=postgresql://rim:rim@localhost:5432/rim_dev

# ── AWS Cognito (Authentication) ──────────────────────────────────────────────
# Not required for APP_ENV=local (dev-token-{userId} is used instead)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── S3 (Document Storage) ─────────────────────────────────────────────────────
S3_BUCKET=rim-documents-dev
# Optional: LocalStack S3 endpoint for local development
# S3_ENDPOINT=http://localhost:4566

# ── SES (Email) ───────────────────────────────────────────────────────────────
# For APP_ENV=local, emails are logged to console — SES is not called
SES_FROM_ADDRESS=noreply@regaxis.ai

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# For APP_ENV=local, AI responses are stubbed — key is still required by config
ANTHROPIC_API_KEY=sk-ant-api03-EXAMPLE

# ── Redis (optional — rate limiting in demo/production) ───────────────────────
# REDIS_URL=redis://localhost:6379
